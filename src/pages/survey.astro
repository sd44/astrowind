---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'SurveyJS 集成指南',
  description: 'SurveyJS 调查问卷集成指南，展示如何在 AstroWind 项目中集成和使用 SurveyJS 库',
};
---

<Layout metadata={metadata}>
  <div class='pt-8 pb-16'>
    <div class='container mx-auto px-4'>
      <div class='mx-auto max-w-6xl'>
        <!-- 页面标题 -->
        <div class='mb-12 text-center'>
          <h1 class='mb-4 text-4xl font-bold text-gray-900 md:text-5xl'>SurveyJS 集成指南</h1>
          <p class='mx-auto max-w-3xl text-xl text-gray-600'>
            在 AstroWind 项目中集成和使用 SurveyJS，创建功能强大的在线调查问卷
          </p>
        </div>

        <!-- 功能简介 -->
        <div class='mb-12 grid grid-cols-1 gap-6 md:grid-cols-3'>
          <div class='rounded-xl border border-blue-100 bg-gradient-to-br from-blue-50 to-indigo-50 p-6'>
            <div class='mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100'>
              <svg
                class='h-6 w-6 text-blue-600'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'
                ></path>
              </svg>
            </div>
            <h3 class='mb-2 text-lg font-semibold text-gray-800'>多种问题类型</h3>
            <p class='text-gray-600'>支持单选、多选、评分、文本输入等 20+ 种问题类型</p>
          </div>

          <div class='rounded-xl border border-green-100 bg-gradient-to-br from-green-50 to-emerald-50 p-6'>
            <div class='mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-green-100'>
              <svg
                class='h-6 w-6 text-green-600'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z'
                ></path>
              </svg>
            </div>
            <h3 class='mb-2 text-lg font-semibold text-gray-800'>响应式设计</h3>
            <p class='text-gray-600'>完美适配桌面、平板和手机等不同设备屏幕</p>
          </div>

          <div class='rounded-xl border border-purple-100 bg-gradient-to-br from-purple-50 to-pink-50 p-6'>
            <div class='mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100'>
              <svg
                class='h-6 w-6 text-purple-600'
                fill='none'
                stroke='currentColor'
                viewBox='0 0 24 24'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M5 13l4 4L19 7'
                ></path>
              </svg>
            </div>
            <h3 class='mb-2 text-lg font-semibold text-gray-800'>自动保存功能</h3>
            <p class='text-gray-600'>填写进度自动保存，关闭页面后可继续填写</p>
          </div>
        </div>

        <!-- 快速开始 -->
        <div class='mb-12 rounded-xl bg-gradient-to-br from-blue-50 to-indigo-50 p-8'>
          <div class='flex items-center mb-6'>
            <div class='mr-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100'>
              <svg class='h-6 w-6 text-blue-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M13 10V3L4 14h7v7l9-11h-7z' />
              </svg>
            </div>
            <div>
              <h2 class='text-2xl font-bold text-gray-900'>快速开始</h2>
              <p class='text-gray-600'>立即体验 SurveyJS 问卷功能</p>
            </div>
          </div>
          
          <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
            <a 
              href='/survey-examples' 
              class='rounded-lg bg-white p-6 border border-blue-200 hover:border-blue-400 hover:shadow-md transition-all'
            >
              <div class='flex items-center mb-4'>
                <div class='mr-3 flex h-10 w-10 items-center justify-center rounded-lg bg-blue-50'>
                  <svg class='h-5 w-5 text-blue-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' />
                  </svg>
                </div>
                <h3 class='text-lg font-semibold text-gray-800'>体验问卷示例</h3>
              </div>
              <p class='text-gray-600 text-sm'>
                查看和体验不同类型的调查问卷，包括客户满意度、产品反馈和员工满意度调查。
              </p>
            </a>
            
            <a 
              href='/survey-manage' 
              class='rounded-lg bg-white p-6 border border-green-200 hover:border-green-400 hover:shadow-md transition-all'
            >
              <div class='flex items-center mb-4'>
                <div class='mr-3 flex h-10 w-10 items-center justify-center rounded-lg bg-green-50'>
                  <svg class='h-5 w-5 text-green-600' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                    <path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' />
                  </svg>
                </div>
                <h3 class='text-lg font-semibold text-gray-800'>管理问卷结果</h3>
              </div>
              <p class='text-gray-600 text-sm'>
                查看历史问卷结果，重新填写问卷，管理数据，导出结果等。
              </p>
            </a>
          </div>
        </div>

        <!-- 使用说明 -->
        <div class='mb-12 rounded-xl bg-gray-50 p-8'>
          <h2 class='mb-6 text-2xl font-bold text-gray-900'>如何在项目中使用 SurveyJS</h2>

          <div class='space-y-6'>
            <div>
              <h3 class='mb-2 text-lg font-semibold text-gray-800'>1. 安装依赖</h3>
              <div class='rounded-lg bg-gray-800 p-4'>
                <pre class='text-sm text-green-400 overflow-auto'>
{`bun add survey-core survey-react-ui @astrojs/react react react-dom`}
                </pre>
              </div>
            </div>

            <div>
              <h3 class='mb-2 text-lg font-semibold text-gray-800'>2. 配置 Astro</h3>
              <div class='rounded-lg bg-gray-800 p-4'>
                <code class='text-sm text-green-400'> // 在 astro.config.ts 中添加 react() 集成 </code>
              </div>
            </div>

            <div>
              <h3 class='mb-2 text-lg font-semibold text-gray-800'>3. 创建调查组件</h3>
              <p class='mb-3 text-gray-600'>
                参考 <code class='text-blue-600'>src/components/survey/</code> 目录中的示例组件
              </p>
              <div class='rounded-lg bg-gray-800 p-4'>
                <pre class='text-sm text-green-400 overflow-auto'>
{`import { Survey } from 'survey-react-ui';
import 'survey-react/defaultV2.css';`}
                </pre>
              </div>
            </div>

            <div>
              <h3 class='mb-2 text-lg font-semibold text-gray-800'>4. 在页面中使用</h3>
              <div class='rounded-lg bg-gray-800 p-4'>
                <code class='text-sm text-green-400'> &lt;SurveyComponent client:load /&gt; </code>
              </div>
            </div>
          </div>
        </div>

        <!-- 应用场景 -->
        <div class='mb-12'>
          <h2 class='mb-6 text-2xl font-bold text-gray-900'>典型应用场景</h2>
          <div class='grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4'>
            <div class='rounded-lg border border-gray-200 bg-white p-6 shadow-sm'>
              <h3 class='mb-2 font-semibold text-gray-800'>客户满意度调查</h3>
              <p class='text-sm text-gray-600'>收集客户反馈，改进产品和服务质量</p>
            </div>
            <div class='rounded-lg border border-gray-200 bg-white p-6 shadow-sm'>
              <h3 class='mb-2 font-semibold text-gray-800'>市场调研</h3>
              <p class='text-sm text-gray-600'>了解目标用户需求，制定市场策略</p>
            </div>
            <div class='rounded-lg border border-gray-200 bg-white p-6 shadow-sm'>
              <h3 class='mb-2 font-semibold text-gray-800'>员工反馈</h3>
              <p class='text-sm text-gray-600'>收集员工意见，改善工作环境</p>
            </div>
            <div class='rounded-lg border border-gray-200 bg-white p-6 shadow-sm'>
              <h3 class='mb-2 font-semibold text-gray-800'>学术研究</h3>
              <p class='text-sm text-gray-600'>进行问卷调查，收集研究数据</p>
            </div>
          </div>
        </div>

        <!-- 相关链接 -->
        <div class='text-center'>
          <div class='inline-flex flex-col gap-4 sm:flex-row'>
            <a
              href='/survey-examples'
              class='rounded-lg bg-blue-600 px-6 py-3 font-medium text-white transition-colors hover:bg-blue-700'
            >
              体验问卷示例
            </a>
            <a
              href='/survey-manage'
              class='rounded-lg bg-green-600 px-6 py-3 font-medium text-white transition-colors hover:bg-green-700'
            >
              查看和管理结果
            </a>
            <a
              href='https://surveyjs.io/'
              target='_blank'
              rel='noopener noreferrer'
              class='rounded-lg bg-purple-600 px-6 py-3 font-medium text-white transition-colors hover:bg-purple-700'
            >
              访问 SurveyJS 官网
            </a>
          </div>
          <p class='mt-4 text-sm text-gray-500'>本页面展示了如何在 AstroWind 模板中集成 SurveyJS 调查问卷功能</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* 自定义 SurveyJS 样式 */
  :global(.survey-container) {
    font-family: inherit;
  }

  :global(.survey-header) {
    background: transparent;
    padding: 0;
    border: none;
  }

  :global(.survey-body) {
    padding: 0;
  }

  :global(.survey-footer) {
    padding: 1.5rem 0 0;
    border: none;
  }

  :global(.btn) {
    padding: 0.5rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  :global(.btn-primary) {
    background-color: #3b82f6;
    color: white;
    border: none;
  }

  :global(.btn-primary:hover) {
    background-color: #2563eb;
  }

  :global(.sd-root-modern) {
    --sjs-font-family: inherit;
    --sjs-general-backcolor: transparent;
  }
</style>
