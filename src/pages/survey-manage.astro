---
import Layout from '~/layouts/PageLayout.astro';
import SurveyResults from '../components/survey/SurveyResults.tsx';

const metadata = {
  title: '问卷管理与结果',
  description: '管理调查问卷数据，查看历史结果，重新填写问卷',
};
---

<Layout metadata={metadata}>
  <div class="pt-8 pb-16">
    <div class="container px-4 mx-auto">
      <div class="max-w-6xl mx-auto">
        <!-- 页面标题 -->
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            问卷管理与结果
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            管理您的调查问卷数据，查看历史结果，重新填写问卷
          </p>
        </div>

        <!-- 功能导航 -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <a 
            href="/survey" 
            class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-6 border border-blue-100 hover:border-blue-300 transition-colors block"
          >
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2">填写问卷</h3>
            <p class="text-gray-600">前往问卷填写页面开始新的调查</p>
          </a>

          <div class="bg-gradient-to-br from-green-50 to-emerald-50 rounded-xl p-6 border border-green-100">
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2">查看结果</h3>
            <p class="text-gray-600">查看所有已保存的问卷结果和统计数据</p>
          </div>

          <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-xl p-6 border border-purple-100">
            <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-800 mb-2">重新填写</h3>
            <p class="text-gray-600">基于历史数据重新填写或开始全新的问卷</p>
          </div>
        </div>

        <!-- 问卷结果展示组件 -->
        <div class="mb-12">
          <SurveyResults client:load />
        </div>

        <!-- 操作指南 -->
        <div class="bg-gray-50 rounded-xl p-8 mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">如何使用问卷管理功能</h2>
          
          <div class="space-y-6">
            <div>
              <h3 class="text-lg font-semibold text-gray-800 mb-2">1. 查看历史结果</h3>
              <p class="text-gray-600">
                在上方的"问卷结果"部分，您可以查看所有已保存的问卷结果。每个结果都包含：
              </p>
              <ul class="list-disc pl-5 text-gray-600 mt-2 space-y-1">
                <li>问卷类型和填写时间</li>
                <li>详细的回答内容</li>
                <li>操作按钮（重新填写、删除等）</li>
              </ul>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-gray-800 mb-2">2. 重新填写问卷</h3>
              <p class="text-gray-600">
                对于每个历史结果，您可以：
              </p>
              <ul class="list-disc pl-5 text-gray-600 mt-2 space-y-1">
                <li><strong>重新填写（基于此结果）</strong>：使用该结果的答案作为初始值重新填写</li>
                <li><strong>重新填写（全新）</strong>：开始一个全新的空白问卷</li>
                <li><strong>前往填写页面</strong>：跳转到问卷填写页面</li>
              </ul>
            </div>

            <div>
              <h3 class="text-lg font-semibold text-gray-800 mb-2">3. 数据管理</h3>
              <p class="text-gray-600">
                您可以管理所有保存的数据：
              </p>
              <ul class="list-disc pl-5 text-gray-600 mt-2 space-y-1">
                <li>删除单个问卷结果</li>
                <li>清除特定问卷类型的所有数据</li>
                <li>查看数据统计信息</li>
                <li>导出数据（JSON格式）</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 数据统计 -->
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">数据存储说明</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
              <h3 class="font-semibold text-gray-800 mb-3">📊 存储位置</h3>
              <p class="text-gray-600 text-sm mb-3">
                所有问卷数据都保存在您的浏览器本地存储（localStorage）中。
              </p>
              <ul class="text-gray-600 text-sm space-y-1">
                <li>• 数据仅保存在您的设备上</li>
                <li>• 不会上传到任何服务器</li>
                <li>• 清除浏览器缓存会删除所有数据</li>
                <li>• 支持离线填写和查看</li>
              </ul>
            </div>
            
            <div class="bg-white rounded-lg border border-gray-200 p-6 shadow-sm">
              <h3 class="font-semibold text-gray-800 mb-3">🔒 隐私保护</h3>
              <p class="text-gray-600 text-sm mb-3">
                我们重视您的隐私，所有数据处理都在本地进行。
              </p>
              <ul class="text-gray-600 text-sm space-y-1">
                <li>• 无需注册或登录</li>
                <li>• 数据完全由您控制</li>
                <li>• 可以随时删除所有数据</li>
                <li>• 不会收集个人信息</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 相关链接 -->
        <div class="text-center">
          <div class="inline-flex flex-col sm:flex-row gap-4">
            <a 
              href="/survey" 
              class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium"
            >
              前往填写问卷
            </a>
            <a 
              href="/" 
              class="px-6 py-3 bg-gray-200 text-gray-800 rounded-lg hover:bg-gray-300 transition-colors font-medium"
            >
              返回首页
            </a>
          </div>
          <p class="text-gray-500 text-sm mt-4">
            本页面用于管理 SurveyJS 调查问卷的数据和结果
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>