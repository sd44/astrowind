---
import Layout from '~/layouts/PageLayout.astro';
import SurveyResults from '../components/survey/SurveyResults.tsx';

const metadata = {
  title: '问卷管理与结果',
  description: '管理调查问卷数据，查看历史结果，重新填写问卷',
};
---

<Layout metadata={metadata}>
  <div class="pt-8 pb-16">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-6xl">
        <!-- 页面标题 -->
        <div class="mb-12 text-center">
          <h1 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">问卷管理与结果</h1>
          <p class="mx-auto max-w-3xl text-xl text-gray-600">管理您的调查问卷数据，查看历史结果，重新填写问卷</p>
        </div>

        <!-- 功能导航 -->
        <div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-3">
          <a
            href="/survey"
            class="block rounded-xl border border-blue-100 bg-gradient-to-br from-blue-50 to-indigo-50 p-6 transition-colors hover:border-blue-300"
          >
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                ></path>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-gray-800">填写问卷</h3>
            <p class="text-gray-600">前往问卷填写页面开始新的调查</p>
          </a>

          <div class="rounded-xl border border-green-100 bg-gradient-to-br from-green-50 to-emerald-50 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-green-100">
              <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-gray-800">查看结果</h3>
            <p class="text-gray-600">查看所有已保存的问卷结果和统计数据</p>
          </div>

          <div class="rounded-xl border border-purple-100 bg-gradient-to-br from-purple-50 to-pink-50 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100">
              <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                ></path>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-gray-800">重新填写</h3>
            <p class="text-gray-600">基于历史数据重新填写或开始全新的问卷</p>
          </div>
        </div>

        <!-- 问卷结果展示组件 -->
        <div class="mb-12">
          <SurveyResults client:load />
        </div>

        <!-- 操作指南 -->
        <div class="mb-12 rounded-xl bg-gray-50 p-8">
          <h2 class="mb-6 text-2xl font-bold text-gray-900">如何使用问卷管理功能</h2>

          <div class="space-y-6">
            <div>
              <h3 class="mb-2 text-lg font-semibold text-gray-800">1. 查看历史结果</h3>
              <p class="text-gray-600">在上方的"问卷结果"部分，您可以查看所有已保存的问卷结果。每个结果都包含：</p>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-gray-600">
                <li>问卷类型和填写时间</li>
                <li>详细的回答内容</li>
                <li>操作按钮（重新填写、删除等）</li>
              </ul>
            </div>

            <div>
              <h3 class="mb-2 text-lg font-semibold text-gray-800">2. 重新填写问卷</h3>
              <p class="text-gray-600">对于每个历史结果，您可以：</p>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-gray-600">
                <li><strong>重新填写（基于此结果）</strong>：使用该结果的答案作为初始值重新填写</li>
                <li><strong>重新填写（全新）</strong>：开始一个全新的空白问卷</li>
                <li><strong>前往填写页面</strong>：跳转到问卷填写页面</li>
              </ul>
            </div>

            <div>
              <h3 class="mb-2 text-lg font-semibold text-gray-800">3. 数据管理</h3>
              <p class="text-gray-600">您可以管理所有保存的数据：</p>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-gray-600">
                <li>删除单个问卷结果</li>
                <li>清除特定问卷类型的所有数据</li>
                <li>查看数据统计信息</li>
                <li>导出数据（JSON格式）</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 数据统计 -->
        <div class="mb-12">
          <h2 class="mb-6 text-2xl font-bold text-gray-900">数据存储说明</h2>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
              <h3 class="mb-3 font-semibold text-gray-800">📊 存储位置</h3>
              <p class="mb-3 text-sm text-gray-600">所有问卷数据都保存在您的浏览器本地存储（localStorage）中。</p>
              <ul class="space-y-1 text-sm text-gray-600">
                <li>• 数据仅保存在您的设备上</li>
                <li>• 不会上传到任何服务器</li>
                <li>• 清除浏览器缓存会删除所有数据</li>
                <li>• 支持离线填写和查看</li>
              </ul>
            </div>

            <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
              <h3 class="mb-3 font-semibold text-gray-800">🔒 隐私保护</h3>
              <p class="mb-3 text-sm text-gray-600">我们重视您的隐私，所有数据处理都在本地进行。</p>
              <ul class="space-y-1 text-sm text-gray-600">
                <li>• 无需注册或登录</li>
                <li>• 数据完全由您控制</li>
                <li>• 可以随时删除所有数据</li>
                <li>• 不会收集个人信息</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 相关链接 -->
        <div class="text-center">
          <div class="inline-flex flex-col gap-4 sm:flex-row">
            <a
              href="/survey"
              class="rounded-lg bg-blue-600 px-6 py-3 font-medium text-white transition-colors hover:bg-blue-700"
            >
              前往填写问卷
            </a>
            <a
              href="/"
              class="rounded-lg bg-gray-200 px-6 py-3 font-medium text-gray-800 transition-colors hover:bg-gray-300"
            >
              返回首页
            </a>
          </div>
          <p class="mt-4 text-sm text-gray-500">本页面用于管理 SurveyJS 调查问卷的数据和结果</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
