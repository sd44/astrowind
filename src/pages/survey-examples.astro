---
import Layout from '~/layouts/PageLayout.astro';
import SurveyExample from '../components/survey/SurveyExample.tsx';

const metadata = {
  title: '问卷示例',
  description: 'SurveyJS 问卷示例页面，展示不同类型的调查问卷',
};
---

<Layout metadata={metadata}>
  <div class="pt-8 pb-16">
    <div class="container mx-auto px-4">
      <div class="mx-auto max-w-6xl">
        <!-- 页面标题 -->
        <div class="mb-12 text-center">
          <h1 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">问卷示例</h1>
          <p class="mx-auto max-w-3xl text-xl text-gray-600">选择不同类型的调查问卷进行体验和测试</p>
        </div>

        <!-- 问卷类型介绍 -->
        <div class="mb-12 grid grid-cols-1 gap-6 md:grid-cols-3">
          <div class="rounded-xl border border-blue-100 bg-gradient-to-br from-blue-50 to-indigo-50 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-blue-100">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-gray-800">客户满意度调查</h3>
            <p class="mb-3 text-gray-600">收集客户反馈，改进产品和服务质量</p>
            <div class="text-sm text-blue-700">
              • 整体满意度评分<br />
              • 产品和服务评价<br />
              • 推荐意愿调查
            </div>
          </div>

          <div class="rounded-xl border border-green-100 bg-gradient-to-br from-green-50 to-emerald-50 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-green-100">
              <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-gray-800">产品反馈调查</h3>
            <p class="mb-3 text-gray-600">了解用户对产品的使用体验和改进建议</p>
            <div class="text-sm text-green-700">
              • 产品易用性评价<br />
              • 设计美观度评分<br />
              • 功能改进建议
            </div>
          </div>

          <div class="rounded-xl border border-purple-100 bg-gradient-to-br from-purple-50 to-pink-50 p-6">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-purple-100">
              <svg class="h-6 w-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                ></path>
              </svg>
            </div>
            <h3 class="mb-2 text-lg font-semibold text-gray-800">员工满意度调查</h3>
            <p class="mb-3 text-gray-600">匿名收集员工意见，改善工作环境</p>
            <div class="text-sm text-purple-700">
              • 工作满意度评分<br />
              • 团队协作氛围评价<br />
              • 管理支持度调查
            </div>
          </div>
        </div>

        <!-- SurveyJS 示例组件 -->
        <div class="mb-12">
          <div class="mb-6 rounded-lg bg-white p-6 shadow-lg">
            <div class="mb-4 flex items-center justify-between">
              <h2 class="text-2xl font-bold text-gray-800">问卷体验区</h2>
              <div class="text-sm text-gray-500">选择下方问卷类型开始体验</div>
            </div>
            <SurveyExample client:load />
          </div>
        </div>

        <!-- 功能特性 -->
        <div class="mb-12 rounded-xl bg-blue-50 p-8">
          <h2 class="mb-6 text-2xl font-bold text-gray-900">SurveyJS 功能特性</h2>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            <div>
              <h3 class="mb-3 text-lg font-semibold text-blue-800">📝 问卷功能</h3>
              <ul class="space-y-2 text-blue-700">
                <li class="flex items-start">
                  <svg class="mt-1 mr-2 h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>支持 20+ 种问题类型（单选、多选、评分、文本等）</span>
                </li>
                <li class="flex items-start">
                  <svg class="mt-1 mr-2 h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>逻辑跳转和条件显示问题</span>
                </li>
                <li class="flex items-start">
                  <svg class="mt-1 mr-2 h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>数据验证和实时预览</span>
                </li>
              </ul>
            </div>

            <div>
              <h3 class="mb-3 text-lg font-semibold text-blue-800">💾 数据管理</h3>
              <ul class="space-y-2 text-blue-700">
                <li class="flex items-start">
                  <svg class="mt-1 mr-2 h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>填写进度自动保存到 localStorage</span>
                </li>
                <li class="flex items-start">
                  <svg class="mt-1 mr-2 h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>问卷结果自动保存和分类</span>
                </li>
                <li class="flex items-start">
                  <svg class="mt-1 mr-2 h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>支持数据导出为 JSON 格式</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 相关链接 -->
        <div class="text-center">
          <div class="inline-flex flex-col gap-4 sm:flex-row">
            <a
              href="/survey"
              class="rounded-lg bg-blue-600 px-6 py-3 font-medium text-white transition-colors hover:bg-blue-700"
            >
              前往集成指南
            </a>
            <a
              href="/survey-manage"
              class="rounded-lg bg-green-600 px-6 py-3 font-medium text-white transition-colors hover:bg-green-700"
            >
              查看和管理结果
            </a>
            <a
              href="/"
              class="rounded-lg bg-gray-200 px-6 py-3 font-medium text-gray-800 transition-colors hover:bg-gray-300"
            >
              返回首页
            </a>
          </div>
          <p class="mt-4 text-sm text-gray-500">本页面展示 SurveyJS 不同类型的问卷示例</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* 自定义 SurveyJS 样式 */
  :global(.survey-container) {
    font-family: inherit;
  }

  :global(.survey-header) {
    background: transparent;
    padding: 0;
    border: none;
  }

  :global(.survey-body) {
    padding: 0;
  }

  :global(.survey-footer) {
    padding: 1.5rem 0 0;
    border: none;
  }

  :global(.btn) {
    padding: 0.5rem 1.5rem;
    border-radius: 0.375rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  :global(.btn-primary) {
    background-color: #3b82f6;
    color: white;
    border: none;
  }

  :global(.btn-primary:hover) {
    background-color: #2563eb;
  }

  :global(.sd-root-modern) {
    --sjs-font-family: inherit;
    --sjs-general-backcolor: transparent;
  }
</style>
